PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=im_chat

# SSL/TLS 配置（用于 TiDB Cloud / Render 等云数据库）
# 可选值: required | true | false
# - required/true: 强制 SSL 连接（生产环境推荐）
# - false: 不使用 SSL（仅本地开发）
DB_SSL_MODE=false

# 是否验证服务器证书（默认为 true）
# 设为 false 可以解决自签名证书问题（不推荐生产环境）
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# 环境标识
NODE_ENV=development
