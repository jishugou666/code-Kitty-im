PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=im_chat

# SSL/TLS 配置（用于 TiDB Cloud / Render 等云数据库）
# 可选值: required | true | false
# - required/true: 强制 SSL 连接（生产环境推荐）
# - false: 不使用 SSL（仅本地开发）
DB_SSL_MODE=false

# 是否验证服务器证书（默认为 true）
# 设为 false 可以解决自签名证书问题（不推荐生产环境）
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# Pusher 实时通信配置 (从 Pusher Dashboard 获取)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_pusher_key_here
PUSHER_SECRET=your_pusher_secret_here

# ImgBB 图片上传配置 (从 https://imgbb.com 获取)
IMGBB_API_KEY=your_imgbb_api_key_here
PUSHER_CLUSTER=ap1
PUSHER_ENCRYPTED=true

# 环境标识
NODE_ENV=development
